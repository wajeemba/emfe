{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://emfe/schema/allocations.json",
	"title": "Allocation list",
	"type": "array",
	"items": { "$ref": "#/$defs/allocation" },
	"$defs": {
		"allocation": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "name", "hz", "layer", "region", "minLod", "note", "source"],
			"properties": {
				"id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
				"name": { "type": "string", "minLength": 1 },
				"hz": { "type": "number", "exclusiveMinimum": 0 },
				"band": {
					"type": "array",
					"items": { "type": "number", "exclusiveMinimum": 0 },
					"minItems": 2,
					"maxItems": 2
				},
				"segments": {
					"type": "array",
					"items": {
						"type": "array",
						"items": { "type": "number", "exclusiveMinimum": 0 },
						"minItems": 2,
						"maxItems": 2
					},
					"minItems": 1
				},
				"lines": {
					"type": "array",
					"items": { "type": "number", "exclusiveMinimum": 0 },
					"minItems": 1
				},
				"layer": {
					"enum": ["consumer", "amateur", "navigation", "gov", "science"]
				},
				"altLayer": {
					"enum": ["consumer", "amateur", "navigation", "gov", "science"]
				},
				"region": {
					"enum": ["radio", "microwave", "infrared", "visible", "uv", "xray", "gamma"]
				},
				"tier": {
					"enum": ["allocation", "assignment", "application"]
				},
				"minLod": { "type": "integer", "minimum": 0, "maximum": 3 },
				"reqLicense": {
					"enum": ["unlicensed", "technician", "general", "extra"]
				},
				"designation": { "enum": ["distress", "calling"] },
				"emission": { "enum": ["spectral", "white"] },
				"optical": { "enum": ["laser", "led", "gas", "fireworks"] },
				"note": { "type": "string", "minLength": 1 },
				"source": { "type": "string", "minLength": 1 },
				"extraSource": {
					"type": "object",
					"additionalProperties": false,
					"required": ["title"],
					"properties": {
						"title": { "type": "string", "minLength": 1 },
						"url": { "type": "string", "minLength": 1 }
					}
				}
			}
		}
	}
}
